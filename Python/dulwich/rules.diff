--- dulwich.debianize/debian/rules	2026-06-10 14:25:28.228123678 +0530
+++ dulwich/debian/rules	2026-06-10 14:27:51.853060073 +0530
@@ -1,3 +1,42 @@
 #!/usr/bin/make -f
+
+export CARGO_HOME=$(shell pwd)/debian/cargo_home
+DPKG_EXPORT_BUILDFLAGS = 1
+include /usr/share/dpkg/buildflags.mk
+
+ifneq (,$(findstring norust,$(DEB_BUILD_PROFILES)))
+export PURE = 1
+endif
+
 %:
-	dh $@ --buildsystem=pybuild
+	dh $* --with python3 --buildsystem=pybuild
+
+override_dh_auto_test:
+ifeq (,$(findstring nocheck,$(DEB_BUILD_OPTIONS)))
+	set -e; for py in $(shell py3versions -s); do \
+		ver=$${py#python}; \
+		builddir=$(CURDIR)/.pybuild/cpython3_$$ver/build; \
+		echo "Running tests with $$py"; \
+		PYTHONHASHSEED=random PYTHONPATH=$$builddir:$(CURDIR) \
+			$$py -m unittest tests.test_suite; \
+	done
+endif
+
+override_dh_auto_clean:
+	if test -f Cargo.lock.saved; then mv Cargo.lock.saved Cargo.lock; fi
+	dh_auto_clean
+	rm -rf build*
+	rm -f dulwich/*.so dulwich/*.o
+
+override_dh_auto_build:
+	mv Cargo.lock Cargo.lock.saved
+	dh_auto_build
+
+override_dh_installdocs:
+	dh_installdocs -ppython3-dulwich docs/tutorial -X.gitignore -XMakefile
+
+override_dh_strip:
+	dh_strip -p python3-dulwich
+
+override_dh_installchangelogs:
+	dh_installchangelogs NEWS
