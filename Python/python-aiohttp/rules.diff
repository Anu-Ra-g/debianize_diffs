--- python-aiohttp.debianize/debian/rules	2026-06-10 14:29:48.347233468 +0530
+++ python-aiohttp/debian/rules	2026-06-10 14:31:55.412692693 +0530
@@ -1,3 +1,75 @@
 #!/usr/bin/make -f
+
+export PYBUILD_NAME = aiohttp
+export PYBUILD_TEST_ARGS=--no-cov \
+    --ignore-glob=tests/test_benchmark* \
+    --ignore=tests/test_imports.py \
+    --ignore=tests/test_pytest_plugin.py \
+    --ignore=tests/test_client_session.py \
+    --ignore=tests/test_proxy_functional.py \
+    --ignore=tests/test_urldispatch.py \
+    --ignore=tests/test_web_response.py \
+    --ignore=tests/test_streams.py \
+    --ignore=tests/test_cookiejar.py \
+    --ignore=tests/test_web_functional.py \
+    --ignore=tests/test_connector.py \
+    --ignore=tests/test_web_sendfile_functional.py \
+    --ignore=tests/autobahn/test_autobahn.py \
+    --ignore=tests/test_client_functional.py \
+    --ignore=tests/test_run_app.py \
+    -k "not test_testcase_no_app and \
+        not test_static_file_directory_traversal_attack and \
+        not test_empty_body and \
+        not test_access_special_resource and \
+        not test_access_mock_special_resource and \
+        not test_ctor and \
+        not test_base_ctor and \
+        not test_cookie_pattern_performance and \
+        not test_regex_performance and \
+        not test_feed_eof_no_err_brotli and \
+        not test_http_response_parser_strict_obs_line_folding and \
+        not test_http_response_parser_strict_headers and \
+        not test_http_response_parser_bad_chunked_strict_py and \
+        not test_http_response_parser_bad_chunked_strict_c and \
+        not test_netrc_auth_from_env and \
+        not test_netrc_auth_skipped_without_env_var and \
+        not test_netrc_auth_overridden_by_explicit_auth and \
+        not test_aiohttp_request_ctx_manager_not_found and \
+        not test_middleware_uses_session_avoids_recursion_with_path_check and \
+        not test_middleware_uses_session_avoids_recursion_with_disabled_middleware and \
+        not test_netrc_auth_skipped_without_netrc_file and \
+        not test_netrc_auth_from_home_directory and \
+        not test_leak and \
+        not test_read_decode_compressed_exceeds_max_size and \
+        not test_parse_set_cookie_headers_uses_unquote_with_octal"
+
+export DEB_BUILD_MAINT_OPTIONS = hardening=+all
+
+# Work around https://bugs.debian.org/1051837
+egg_info := aiohttp.egg-info
+egg_info_safe := debian/aiohttp.egg-info.safe
+define save-egg-info =
+if [ ! -d $(egg_info_safe) ]; then cp -a $(egg_info) $(egg_info_safe); fi
+endef
+define restore-egg-info =
+if [ -d $(egg_info_safe) ]; then rm -rf $(egg_info); cp -a $(egg_info_safe) $(egg_info); fi
+endef
+
 %:
-	dh $@ --buildsystem=pybuild
+	dh $@ --with python3,sphinxdoc --buildsystem pybuild
+
+override_dh_auto_build:
+	$(save-egg-info)
+	# Ignore missing references.
+	${MAKE} -C docs html SPHINXOPTS=
+	dh_auto_build
+	find . -type d -name '.hash' -exec rm -rf {} +
+
+override_dh_auto_clean:
+	rm -rf .cache
+	$(save-egg-info)
+	dh_auto_clean
+	$(restore-egg-info)
+
+override_dh_strip:
+	dh_strip --dbgsym-migration='python3-aiohttp-dbg (<< 3.7.4-2~)'
